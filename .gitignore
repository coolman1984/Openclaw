# Secrets / local auth
.opencode/
*.env
*.key
*.secret
*.token
*.pem
*.json.local

# Runtime databases and caches
*.db
*.sqlite
*.sqlite3
*.sqlite-wal
*.sqlite-shm
*.wal
*.shm
__pycache__/
*.pyc

# Memory system generated runtime artifacts
memory-system/data/
memory-system/backups/
memory-system/memory-config.json
memory-system/MEMORY.md
memory-system/MEMORY.v3.md

# Generated / downloaded artifacts
node_modules/
package.json
package-lock.json
*.tar.gz
*.deb
ripgrep-*/
rust-*/

# Backup archives
memory-backups/
backup/
backups/

# Sensitive local state
.openclaw/workspace-state.json

# Keep the human-readable memory docs, but not raw DB files
!memory/*.md
!memory-system/**/*.md
!memory-system/**/*.py
!memory-system/**/*.sh
!memory-system/**/*.txt

# Re-ignore generated dashboard files after the broad doc allow-list above
memory-system/MEMORY.md
memory-system/MEMORY.v3.md
